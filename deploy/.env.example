# ── Required ────────────────────────────────────────────────────────────
# Your domain. A DNS A record for it MUST point to this server's public IP
# before you start (Caddy needs it to issue the HTTPS certificate).
DOMAIN=play.yourdomain.com

# Random shared secret (any long string). Generate: openssl rand -hex 32
API_KEY=replace_with_random_hex

# ── Optional (sensible defaults in docker-compose.yml) ──────────────────
# Game-server workers. 1–2 is plenty for a few players (≈ vCPUs − 1).
NUM_WORKERS=2

# Cloudflare Turnstile bot-check is DISABLED for private servers
# (DISABLE_TURNSTILE=true in docker-compose.yml). This always-pass test key
# only renders the widget; replace with a real key if you ever make it public.
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Enables the trusted admin-bot HTTP API if set; leave empty to disable.
ADMIN_BOT_API_KEY=

# Build/version stamp. Optional.
GIT_COMMIT=selfhost
